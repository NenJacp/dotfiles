# Paleta (Oxocarbon de ejemplo)
set $background  #161616
set $foreground  #f4f4f4
set $color0      #262626
set $color1      #37474f
set $color3      #be95ff

# class                 border  bground text    indicator child_border
client.focused          $color1 $background $foreground $color3   $color1
client.focused_inactive $color0 $background $foreground $color0   $color0
client.unfocused        $color0 $background $foreground $color0   $color0
client.urgent           $color0 $background $foreground $color0   $color0
client.placeholder      #000000 #0C0C0C $foreground #000000   #0C0C0C

